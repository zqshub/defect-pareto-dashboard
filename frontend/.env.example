# LLM API 配置
# 复制此文件为 .env 并填入你的真实配置

# API Key（必填）
VITE_LLM_API_KEY=sk-your-api-key-here

# API Base URL（必填，不同平台不同）
# OpenAI 官方: https://api.openai.com/v1
# 硅基流动: https://api.siliconflow.cn/v1
# 月之暗面 Kimi: https://api.moonshot.cn/v1
# CloseAI: https://api.closeai-asia.com/v1
VITE_LLM_BASE_URL=https://api.closeai-asia.com/v1

# 模型名称
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# 硅基流动: deepseek-ai/DeepSeek-V3, deepseek-ai/DeepSeek-R1
# 月之暗面: moonshot-v1-8k, moonshot-v1-32k
# CloseAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
VITE_LLM_MODEL=gpt-4o
